// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id          String        @id @unique @default(uuid())
    email       String        @unique
    username    String?
    telephone    String?
    role        Role          @default(Guru)
    password    String
    isVerified  Boolean       @default(false)
    otps        Otp[]

    pelajaran Pelajaran[]
}

model Otp {
  id        String      @id @unique @default(uuid())
  userId    String?
  email     String
  code      String
  type      String   
  metadata  String?
  expiresAt DateTime
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])
}

model Siswa {
  id           String      @id @unique @default(uuid())
  nis          String?
  namaSiswa         String 
  tanggalLahir DateTime
  kelasId      String?
  tahunAjaranId String?
  createdAt    DateTime   @default(now())
  updateAt     DateTime   @updatedAt

  nilai        Nilai[]
  nilaiKriteria NilaiKriteria[]
  pelajaran Pelajaran[]
  hafalan Hafalan[]
  poinPlus PoinPlus[]
  poinMinus PoinMinus[]
  eskul SiswaEskul[]
  kehadiran Kehadiran[]
  ranking Ranking[]

  tahunAjaran TahunAjaran? @relation(fields: [tahunAjaranId], references: [id])
  kelas Kelas? @relation(fields: [kelasId], references: [id])
}

model Kelas {
  id String @id @default(uuid())
  kodeKelas String
  namaKelas String

  siswa Siswa[]
  pertemuan Pertemuan[]
}

model Nilai {
  id                String      @id @unique @default(uuid())
  nilai             Float

  siswaId           String    
  pelajaranId   String
  tahunAjaranId String

  siswa             Siswa           @relation(fields: [siswaId],  references: [id])
  pelajaran     Pelajaran   @relation(fields: [pelajaranId], references: [id])
  tahunAjaran TahunAjaran @relation(fields: [tahunAjaranId], references: [id])

   @@unique([siswaId, pelajaranId]) 
}

model Kriteria {
  id           String   @id @default(uuid())
  namaKriteria String
  bobot        Float
  jenis        String   // benefit atau cost

  nilaiKriteria NilaiKriteria[]
}

model NilaiKriteria {
  id            String   @id @default(uuid())

  siswaId       String
  kriteriaId    String
  nilai         Float

  siswa         Siswa @relation(fields: [siswaId], references: [id])
  kriteria      Kriteria @relation(fields: [kriteriaId], references: [id])

  @@unique([siswaId, kriteriaId])
}

model Pelajaran {
  id String @id @default(uuid())
  namaPelajaran String
  kodePelajaran String

  nilai Nilai[]
  user User[]
  siswa Siswa[]
}

model Hafalan {
  id            String   @id @default(uuid())
  siswaId String @unique

  siswa Siswa @relation(fields: [siswaId], references: [id])

  jumlahJuz Int
}

model PoinPlus {
  id            String   @id @default(uuid())
  siswaId String 

  siswa Siswa @relation(fields: [siswaId], references: [id])

  deskripsi String
  poin Int
  tanggal DateTime @default(now())
}

model PoinMinus {
  id String @id @default(uuid())
  siswaId String

  siswa Siswa @relation(fields: [siswaId], references: [id])

  deskripsi String
  poin Int
  tanggal DateTime @default(now())
}

model Eskul {
  id String @id @default(uuid())
  namaEskul String

  siswa SiswaEskul[]
}
model SiswaEskul {
  id String @id @default(uuid())
  siswaId String
  eskulId String

  siswa Siswa @relation(fields: [siswaId], references: [id])
  eskul Eskul @relation(fields: [eskulId], references: [id])
}

model Kehadiran {
  id String @id @default(uuid())
  tahunAjaranId String?
  pertemuanId String
  siswaId String
  statusKehadiran StatusKehadiran @default(Alpha)
  tanggalKehadiran DateTime @default(now())

  siswa Siswa @relation(fields: [siswaId], references: [id])
  tahunAjaran TahunAjaran? @relation(fields: [tahunAjaranId], references: [id])
  pertemuan Pertemuan @relation(fields: [pertemuanId], references: [id])
  @@unique([siswaId, tanggalKehadiran])
}

model Pertemuan {
  id String @id @default(uuid())
  tahunAjaranId String?
  tanggal DateTime
  kelasId String?
  namaPertemuan String
  createdAt DateTime @default(now())

  tahunAjaran TahunAjaran? @relation(fields: [tahunAjaranId], references: [id])
  kelas Kelas? @relation(fields: [kelasId], references: [id])
  kehadiran Kehadiran[]
}

model Ranking {
  id String @id @default(uuid())
  tahunAjaranId String
  siswaId String
  nilaiAkhir Float
  peringkat Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  siswa Siswa @relation(fields: [siswaId], references: [id])
  tahunAjaran TahunAjaran @relation(fields: [tahunAjaranId], references: [id])
  @@unique([siswaId, tahunAjaranId])
}

enum StatusKehadiran {
  Hadir
  Izin
  Sakit
  Alpha
}

enum Role {
  Guru
  WaliKelas
  KepalaSekolah
  WakilKepalaSekolah
  Admin
}

model TahunAjaran {
  id String @id @default(uuid())
  namaTahunAjaran String
  status StatusTahunAjaran @default(Aktif)

  siswa Siswa[]
  kehadiran Kehadiran[]
  nilai Nilai[]
  ranking Ranking[]
  pertemuan Pertemuan[]
}

enum StatusTahunAjaran {
  Aktif
  Nonaktif
}